class Solution:
    def containsNearbyAlmostDuplicate(self, nums, k, t):
        if t < 0:
            return False
        
        buckets = {}
        width = t + 1  # bucket size
        
        for i, num in enumerate(nums):
            bucket_id = num // width
            
            # same bucket
            if bucket_id in buckets:
                return True
            
            # neighbor buckets
            if (bucket_id - 1 in buckets and 
                abs(num - buckets[bucket_id - 1]) < width):
                return True
            
            if (bucket_id + 1 in buckets and 
                abs(num - buckets[bucket_id + 1]) < width):
                return True
            
            buckets[bucket_id] = num
            
            # maintain window size k
            if i >= k:
                del buckets[nums[i - k] // width]
        
        return False
