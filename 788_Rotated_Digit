class Solution:
    def rotatedDigits(self, n: int) -> int:
        good_count = 0

        for num in range(1, n + 1):
            s = str(num)

            valid = True
            changed = False

            for digit in s:
                if digit in "347":
                    valid = False
                    break

                if digit in "2569":
                    changed = True

            if valid and changed:
                good_count += 1

        return good_count
