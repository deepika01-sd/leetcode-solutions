class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        if len(s) != len(goal):
            return False
        
        temp = s + s
        
        for i in range(len(temp) - len(goal) + 1):
            match = True
            
            for j in range(len(goal)):
                if temp[i + j] != goal[j]:
                    match = False
                    break
            
            if match:
                return True
        
        return False
